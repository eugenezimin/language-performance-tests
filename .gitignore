# ─────────────────────────────────────────────────────────────
# Cross-language concurrency benchmark suite
# Covers: Rust, Go, Node.js/JS, Python, Java, Gradle
# ─────────────────────────────────────────────────────────────

# ── OS / editor cruft ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini
*~
.idea/
.vscode/
*.swp
*.swo
*.iml

# ─────────────────────────────────────────────────────────────
# Rust  (cpu/rust/)
# ─────────────────────────────────────────────────────────────
target/
**/*.rs.bk
*.pdb
# Keep Cargo.lock for binaries; uncomment to ignore for libraries
# Cargo.lock

# ─────────────────────────────────────────────────────────────
# Go  (cpu/go/)
# ─────────────────────────────────────────────────────────────
# Compiled binaries / test artifacts
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
# Build output dirs
/bin/
/dist/
# Go workspace file
go.work
go.work.sum
# vendor/ — uncomment if you don't commit vendored deps
# vendor/

# ─────────────────────────────────────────────────────────────
# Node.js / JavaScript  (cpu/node/  cpu/js/)
# ─────────────────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.npm/
.pnpm-store/
.yarn/
.node_repl_history
*.tsbuildinfo
.eslintcache
# Lockfiles are usually committed — leave them in.

# ─────────────────────────────────────────────────────────────
# Python  (cpu/python/)
# ─────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg
.installed.cfg
# Virtual environments
.venv/
venv/
env/
ENV/
# Tooling caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.ipynb_checkpoints/
# matplotlib / plot output — keep these tracked if you commit charts:
# *.png
# *.svg

# ─────────────────────────────────────────────────────────────
# Java  (cpu/java/)
# ─────────────────────────────────────────────────────────────
*.class
*.jar
*.war
*.ear
*.nar
hs_err_pid*
replay_pid*
# Compiled output
bin/
out/

# ─────────────────────────────────────────────────────────────
# Gradle  (cpu/java/)
# ─────────────────────────────────────────────────────────────
.gradle/
build/
gradle-app.setting
!gradle-wrapper.jar
!gradle-wrapper.properties
.gradletasknamecache
# Keep the wrapper itself committed (gradlew, gradlew.bat, gradle/wrapper/)

# ─────────────────────────────────────────────────────────────
# Benchmark artifacts (optional)
# ─────────────────────────────────────────────────────────────
# Raw timing dumps / generated results — uncomment if you don't
# want measured output committed:
# results/
# *.bench.json
# *.csv
/cpu/java/gradle
/cpu/java/gradlew
/cpu/java/gradlew.bat
